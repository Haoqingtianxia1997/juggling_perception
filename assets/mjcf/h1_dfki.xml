<mujoco model="h1">
  <compiler angle="radian" meshdir="../meshes" autolimits="true" />
  <option iterations="3" ls_iterations="5" timestep="0.002" integrator="Euler">
    <flag eulerdamp="disable" />
  </option>

  <default>
    <default class="h1">
      <geom type="mesh" contype="0" conaffinity="0" />
      <position inheritrange="1" dampratio="1" />

      <default class="strong_motor">
        <joint damping="0.001" armature="0.01" frictionloss="0.1" />
      </default>
      <default class="weak_motor">
        <joint damping="0.001" armature="0.01" frictionloss="0.1" />
      </default>

      <default class="visual">
        <geom contype="0" conaffinity="0" group="1" material="black" />
      </default>
      <default class="collision">
        <geom group="2" mass="0" density="0" />
        <default class="foot">
          <geom type="capsule" size=".014" contype="0" conaffinity="1" friction="1.0" />
          <default class="foot1">
            <geom fromto="-.035 0 -0.056 .02 0 -0.045" />
          </default>
          <default class="foot2">
            <geom fromto=".02 0 -0.045 .115 0 -0.056" />
          </default>
          <default class="foot3">
            <geom fromto=".145 -.0 -0.056 .19 .0 -0.056" />
          </default>
          <default class="foot4">
            <geom fromto="-.06 -.0 -0.056 -.086 .0 -0.056" />
          </default>
        </default>
      </default>

      <default class="mimic">
        <site group="4" type="box" size="0.075 0.05 0.025" rgba="1.0 0.0 0.0 0.5" />
      </default>

      <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4" />

      <motor ctrllimited="true" />
    </default>
  </default>

