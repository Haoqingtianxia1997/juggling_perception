<mujoco model="h1">
  <compiler angle="radian" meshdir="../meshes" autolimits="true" />
  <option iterations="3" ls_iterations="5" timestep="0.002" integrator="Euler">
    <flag eulerdamp="disable" />
  </option>

  <visual>
    <global offwidth="360" offheight="640"/>
  </visual>

  <default>
    <default class="h1">
      <geom type="mesh" contype="0" conaffinity="0" />
      <position inheritrange="1" dampratio="1" />

      <default class="strong_motor">
        <joint damping="0.001" armature="0.01" frictionloss="0.1" />
      </default>
      <default class="weak_motor">
        <joint damping="0.001" armature="0.01" frictionloss="0.1" />
      </default>

      <default class="visual">
        <geom contype="0" conaffinity="0" group="1" material="black" />
      </default>

      <default class="collision">
        <geom group="2" mass="0" density="0" />
        <default class="foot">
          <geom type="capsule" size=".014" contype="0" conaffinity="1" friction="1.0" />
          <default class="foot1">
            <geom fromto="-.035 0 -0.056 .02 0 -0.045" />
          </default>
          <default class="foot2">
            <geom fromto=".02 0 -0.045 .115 0 -0.056" />
          </default>
          <default class="foot3">
            <geom fromto=".145 -.0 -0.056 .19 .0 -0.056" />
          </default>
          <default class="foot4">
            <geom fromto="-.06 -.0 -0.056 -.086 .0 -0.056" />
          </default>
        </default>
      </default>

      <default class="cup_collision">
        <!-- <geom group="3" mass="0" density="0" contype="0" conaffinity="1" mesh="cup_piece" pos="0. 0.14 0." /> -->
        <geom group="3" mass="0" density="0" contype="0" conaffinity="1" mesh="cup_piece10" pos="0. 0.14 0." />
      </default>

      <default class="ball">
        <geom type="sphere" size="0.0375" mass="0.048" contype="1" conaffinity="1" group="1" rgba="0.8 0.15 0.15 1"
          solref="-50000 -200" condim="6" friction="0.2 0 0.05" />
      </default>

      <default class="mimic">
        <site group="4" type="box" size="0.075 0.05 0.025" rgba="1.0 0.0 0.0 0.5" />
      </default>

      <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4" />

      <motor ctrllimited="true" />
    </default>
  </default>

  <asset>
    <material name="black" rgba="0.2 0.2 0.2 1" />
    <material name="white" rgba="1 1 1 1" />
    <texture name="tex_ground" type="2d" builtin="checker" width="1024" height="1024"
         rgb1="0.12 0.20 0.32" rgb2="0.20 0.30 0.45" mark="edge" markrgb="0.30 0.42 0.58" />
    <material name="mat_ground" texture="tex_ground" texrepeat="10 10" texuniform="true"
              reflectance="0.05" shininess="0.05" specular="0.05" />

